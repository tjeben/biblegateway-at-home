      {
        "r": "1CO.4.15",
        "v": 8
      },
      {
        "r": "GAL.4.19",
        "v": 7
      },
      {
        "r": "1TI.1.2",
        "v": 7
      },
      {
        "r": "TIT.1.4",
        "v": 6
      },
      {
        "r": "2SA.19.37-38",
        "v": 5
      },
      {
        "r": "2SA.18.5",
        "v": 4
      },
      {
        "r": "2SA.9.1-7",
        "v": 4
      },
      {
        "r": "MRK.9.17",
        "v": 3
      }
    ],
    "section": null
  },
