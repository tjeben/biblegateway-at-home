        "r": "ROM.16.5",
        "v": 6
      },
      {
        "r": "COL.4.15",
        "v": 4
      },
      {
        "r": "2TI.2.3-4",
        "v": 3
      },
      {
        "r": "1CO.16.19",
        "v": 3
      }
    ],
    "section": null
  },
  "PHM.1.3": {
    "text": "Grace to you and peace from God our Father and the Lord Jesus Christ.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ROM.1.7",
        "v": 5
      },
      {
        "r": "EPH.1.2",
        "v": 4
      },
      {
        "r": "2CO.13.14",
        "v": 3
      }
    ],
    "section": null
  },
