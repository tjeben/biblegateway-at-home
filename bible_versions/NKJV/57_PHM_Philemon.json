    "footnotes": [],
    "xrefs": [
      {
        "r": "2TH.3.4",
        "v": 5
      },
      {
        "r": "2CO.2.3",
        "v": 4
      },
      {
        "r": "2CO.7.16",
        "v": 3
      },
      {
        "r": "2CO.8.22",
        "v": 2
      },
      {
        "r": "GAL.5.10",
        "v": 2
      }
    ],
    "section": null
  },
