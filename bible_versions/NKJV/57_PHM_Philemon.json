    "text": "no longer as a slave but more than a slave—a beloved brother, especially to me but how much more to you, both in the flesh and in the Lord.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "COL.3.22",
        "v": 6
      },
      {
        "r": "MAT.23.8",
        "v": 6
      },
      {
        "r": "1TI.6.2",
        "v": 5
      },
      {
        "r": "1CO.7.22",
        "v": 5
      },
      {
        "r": "EPH.6.5-7",
        "v": 4
      },
      {
        "r": "1PE.1.22-23",
        "v": 3
      },
      {
        "r": "ACT.9.17",
        "v": 2
      },
      {
        "r": "HEB.3.1",
        "v": 2
      },
      {
        "r": "GAL.4.28-29",
        "v": 2
      },
      {
        "r": "1JN.5.1",
        "v": 1
      }
    ],
    "section": null
  },
