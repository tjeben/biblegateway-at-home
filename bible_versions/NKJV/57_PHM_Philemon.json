      {
        "r": "PHM.1.7",
        "v": 2
      },
      {
        "r": "GAL.5.6",
        "v": 2
      },
      {
        "r": "ROM.15.25-26",
        "v": 2
      },
      {
        "r": "ROM.12.13",
        "v": 2
      },
      {
        "r": "ACT.9.39-41",
        "v": 1
      }
    ],
    "section": null
  },
