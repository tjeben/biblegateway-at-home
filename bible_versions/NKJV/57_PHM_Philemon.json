        "r": "2TH.1.3",
        "v": 4
      },
      {
        "r": "1TH.1.2",
        "v": 4
      },
      {
        "r": "2TI.1.3",
        "v": 2
      }
    ],
    "section": "Philemon’s Love and Faith"
