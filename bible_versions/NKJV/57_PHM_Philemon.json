    "text": "But, meanwhile, also prepare a guest room for me, for I trust that through your prayers I shall be granted to you.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2CO.1.11",
        "v": 5
      },
      {
        "r": "PHP.2.24",
        "v": 5
      },
      {
        "r": "2JN.1.12",
        "v": 3
      },
      {
        "r": "JAS.5.16",
        "v": 3
      },
      {
        "r": "ACT.28.23",
        "v": 3
      },
      {
        "r": "PHP.1.19",
        "v": 3
      },
      {
        "r": "HEB.13.19",
        "v": 2
      },
      {
        "r": "PHP.1.25-26",
        "v": 2
      },
      {
        "r": "ROM.15.30-32",
        "v": 2
      },
      {
        "r": "ROM.15.24",
        "v": 2
      },
      {
        "r": "3JN.1.14",
        "v": 2
      },
      {
        "r": "HEB.13.23",
        "v": 2
      }
    ],
    "section": null
