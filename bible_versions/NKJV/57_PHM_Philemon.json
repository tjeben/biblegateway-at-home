    "section": "Greeting"
  },
  "PHM.1.2": {
    "text": "to the beloved Apphia, Archippus our fellow soldier, and to the church in your house:",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PHP.2.25",
        "v": 7
      },
      {
        "r": "COL.4.17",
        "v": 6
