    "footnotes": [],
    "xrefs": [
      {
        "r": "PHM.1.7",
        "v": 5
      },
      {
        "r": "3JN.1.4",
        "v": 4
      },
      {
        "r": "PHM.1.12",
        "v": 3
      },
      {
        "r": "HEB.13.17",
        "v": 3
      },
      {
        "r": "1TH.2.19-20",
        "v": 2
      },
      {
        "r": "2CO.2.2",
        "v": 2
      },
      {
        "r": "1JN.3.17",
        "v": 2
      },
      {
        "r": "2CO.7.4-7",
        "v": 2
      },
      {
        "r": "2CO.7.13",
        "v": 2
      },
