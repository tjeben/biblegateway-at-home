      {
        "r": "1TI.6.2",
        "v": 1
      },
      {
        "r": "HEB.3.14",
        "v": 1
      },
      {
        "r": "PHP.1.7",
        "v": 1
      },
      {
        "r": "1PE.5.1",
        "v": 1
      },
      {
        "r": "1JN.1.3",
        "v": 1
      },
      {
        "r": "PHM.1.10",
        "v": 1
      }
    ],
    "section": "Philemon’s Obedience Encouraged"
  },
  "PHM.1.18": {
    "text": "But if he has wronged you or owes anything, put that on my account.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ISA.53.4-7",
        "v": 7
      }
    ],
    "section": null
  },
  "PHM.1.19": {
    "text": "I, Paul, am writing with my own hand. I will repay—not to mention to you that you owe me even your own self besides.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "GAL.6.11",
        "v": 4
      },
      {
        "r": "GAL.5.2",
        "v": 3
      },
      {
        "r": "1CO.16.21-22",
        "v": 3
      },
      {
        "r": "JAS.5.19-20",
        "v": 2
      },
      {
        "r": "1CO.4.15",
        "v": 2
      },
      {
        "r": "1CO.9.1-2",
        "v": 2
      },
      {
        "r": "2CO.3.2",
        "v": 1
      },
      {
        "r": "TIT.1.4",
        "v": 1
      },
      {
        "r": "1TI.1.2",
        "v": 1
      }
    ],
    "section": null
  },
