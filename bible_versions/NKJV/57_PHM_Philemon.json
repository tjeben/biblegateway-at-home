      {
        "r": "1PE.1.5-8",
        "v": 5
      },
      {
        "r": "MAT.5.16",
        "v": 5
      },
      {
        "r": "TIT.3.14",
        "v": 4
      },
      {
        "r": "2CO.9.12-14",
        "v": 4
      },
      {
        "r": "1PE.2.12",
        "v": 4
      },
      {
        "r": "JAS.2.17",
        "v": 4
