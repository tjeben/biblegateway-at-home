      {
        "r": "JAS.2.5",
        "v": 2
      },
      {
        "r": "HEB.3.1",
        "v": 2
      },
      {
        "r": "MAT.12.48-50",
        "v": 2
      },
      {
        "r": "ACT.16.15",
        "v": 2
      },
      {
        "r": "MAT.25.40",
        "v": 2
