    "footnotes": [],
    "xrefs": [
      {
        "r": "COL.4.14",
        "v": 6
      },
      {
        "r": "2TI.4.10-11",
        "v": 6
      },
      {
        "r": "COL.4.10",
        "v": 6
      },
      {
        "r": "ACT.15.37-39",
        "v": 4
      },
      {
        "r": "ACT.12.12",
        "v": 4
      },
      {
        "r": "ACT.19.29",
        "v": 4
      },
      {
        "r": "PHM.1.1-2",
        "v": 3
      },
      {
        "r": "ACT.12.25",
        "v": 3
      },
      {
        "r": "ACT.27.2",
        "v": 3
      },
      {
        "r": "PHP.4.3",
        "v": 2
      },
      {
        "r": "2CO.8.23",
        "v": 2
      },
      {
        "r": "3JN.1.8",
        "v": 2
      },
      {
        "r": "ACT.13.13",
        "v": 2
      },
