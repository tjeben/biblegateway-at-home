{
  "PHM.1.1": {
    "text": "Paulus, Kristi Jesu fange, og vår bror Timoteus - til vår kjære venn og medarbeider Filemon,",
    "footnotes": [],
    "xrefs": [
      {
        "r": "EPH.3.1",
        "v": 5
      },
      {
        "r": "PHM.1.9",
        "v": 5
      },
      {
        "r": "COL.1.1",
        "v": 5
      },
      {
        "r": "PHP.2.25",
        "v": 5
      },
      {
        "r": "1CO.3.9",
        "v": 4
      },
      {
        "r": "PHP.4.3",
        "v": 3
      },
      {
        "r": "2CO.1.1",
        "v": 3
      },
      {
        "r": "COL.4.11",
        "v": 3
      },
      {
        "r": "2TI.1.8",
        "v": 3
      },
      {
        "r": "1TH.3.2",
        "v": 3
      },
      {
        "r": "EPH.4.1",
        "v": 3
      },
      {
        "r": "PHM.1.24",
        "v": 2
      },
      {
        "r": "EPH.6.20",
        "v": 2
      },
      {
        "r": "2TH.1.1",
        "v": 2
      }
    ],
    "section": "Hilsen"
  },
  "PHM.1.2": {
    "text": "og til vår søster Appia, og til vår medstrider Arkippus, og til menigheten i ditt hus:",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PHP.2.25",
        "v": 7
      },
      {
        "r": "COL.4.17",
        "v": 6
      },
      {
        "r": "ROM.16.5",
        "v": 6
      },
      {
        "r": "COL.4.15",
        "v": 4
      },
      {
        "r": "2TI.2.3-4",
        "v": 3
      },
      {
        "r": "1CO.16.19",
        "v": 3
      }
    ],
    "section": null
  },
  "PHM.1.3": {
    "text": "Nåde være med dere og fred fra Gud, vår Far, og Herren Jesus Kristus!",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ROM.1.7",
        "v": 5
      },
      {
        "r": "EPH.1.2",
        "v": 4
      },
      {
        "r": "2CO.13.14",
        "v": 3
      }
    ],
    "section": null
  },
  "PHM.1.4": {
    "text": "Jeg takker alltid Gud når jeg minnes deg i bønnene mine.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ROM.1.8",
        "v": 7
      },
      {
        "r": "EPH.1.16",
        "v": 6
      },
      {
        "r": "COL.1.3",
        "v": 5
      },
      {
        "r": "PHP.1.3",
        "v": 5
      },
      {
        "r": "2TH.1.3",
        "v": 4
      },
      {
        "r": "1TH.1.2",
        "v": 4
      },
      {
        "r": "2TI.1.3",
        "v": 2
      }
    ],
    "section": "Takk for Filemon"
  },
  "PHM.1.5": {
    "text": "For jeg hører om din kjærlighet og den tro som du har til Herren Jesus og til alle de hellige.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "COL.1.4",
        "v": 10
      },
      {
        "r": "EPH.1.15",
        "v": 7
      },
      {
        "r": "PSA.16.3",
        "v": 3
      },
      {
        "r": "1CO.16.1",
        "v": 3
      },
      {
        "r": "1JN.5.1-2",
        "v": 3
      },
      {
        "r": "1JN.3.23",
        "v": 2
      },
      {
        "r": "PHM.1.7",
        "v": 2
      },
      {
        "r": "GAL.5.6",
        "v": 2
      },
      {
        "r": "ROM.15.25-26",
        "v": 2
      },
      {
        "r": "ROM.12.13",
        "v": 2
      },
      {
        "r": "ACT.9.39-41",
        "v": 1
      }
    ],
    "section": null
  },
  "PHM.1.6": {
    "text": "Jeg ber om at deres samfunn med deg i troen må være virksomt ved innsikt i alt det gode vi har i Kristus.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2PE.1.8",
        "v": 13
      },
      {
        "r": "PHP.1.9-11",
        "v": 13
      },
      {
        "r": "COL.1.9",
        "v": 8
      },
      {
        "r": "1PE.1.5-8",
        "v": 5
      },
      {
        "r": "MAT.5.16",
        "v": 5
      },
      {
        "r": "TIT.3.14",
        "v": 4
      },
      {
        "r": "2CO.9.12-14",
        "v": 4
      },
      {
        "r": "1PE.2.12",
        "v": 4
      },
      {
        "r": "JAS.2.17",
        "v": 4
      },
      {
        "r": "JAS.2.14",
        "v": 4
      },
      {
        "r": "HEB.6.10",
        "v": 3
      },
      {
        "r": "1CO.14.25",
        "v": 3
      },
      {
        "r": "PHP.4.8",
        "v": 3
      },
      {
        "r": "1PE.3.16",
        "v": 3
      },
      {
        "r": "1PE.3.1",
        "v": 2
      }
    ],
    "section": null
  },
  "PHM.1.7": {
    "text": "For jeg har fått stor glede og trøst ved din kjærlighet, fordi de helliges hjerter er blitt styrket ved deg, bror.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2CO.7.13",
        "v": 10
      },
      {
        "r": "1TH.3.9",
        "v": 6
      },
      {
        "r": "2CO.7.4",
        "v": 6
      },
      {
        "r": "PHM.1.20",
        "v": 5
      },
      {
        "r": "3JN.1.3-6",
        "v": 5
      },
      {
        "r": "1TH.2.19",
        "v": 5
      },
      {
        "r": "2JN.1.4",
        "v": 4
      },
      {
        "r": "2TI.1.16",
        "v": 4
      },
      {
        "r": "1TH.1.3",
        "v": 2
      },
      {
        "r": "1TH.2.13",
        "v": 2
      }
    ],
    "section": null
  },
  "PHM.1.8": {
    "text": "Derfor, selv om jeg i Kristus med stor frimodighet kunne pålegge deg å gjøre det som er din plikt,",
    "footnotes": [],
    "xrefs": [
      {
        "r": "1TH.2.6",
        "v": 8
      },
      {
        "r": "2CO.10.8",
        "v": 4
      },
      {
        "r": "2CO.3.12",
        "v": 3
      },
      {
        "r": "EPH.5.4",
        "v": 2
      },
      {
        "r": "2CO.10.1-2",
        "v": 2
      },
      {
        "r": "1TH.2.2",
        "v": 2
      },
      {
        "r": "2CO.11.21",
        "v": 2
      }
    ],
    "section": "Filemon og Onesimus"
  },
  "PHM.1.9": {
    "text": "så vil jeg heller be deg om dette, for kjærlighetens skyld. Slik som jeg er, den gamle Paulus, nå også Kristi Jesu fange,",
    "footnotes": [],
    "xrefs": [
      {
        "r": "EPH.4.1",
        "v": 4
      },
      {
        "r": "ROM.12.1",
        "v": 4
      },
      {
        "r": "2CO.5.20",
        "v": 4
      },
      {
        "r": "EPH.3.1",
        "v": 3
      },
      {
        "r": "PHM.1.1-25",
        "v": 2
      },
      {
        "r": "1PE.2.11",
        "v": 1
      },
      {
        "r": "ISA.46.4",
        "v": 1
      },
      {
        "r": "PSA.71.9",
        "v": 1
      },
      {
        "r": "PRO.16.31",
        "v": 1
      },
      {
        "r": "HEB.13.19",
        "v": 1
      },
      {
        "r": "2CO.6.1",
        "v": 1
      },
      {
        "r": "PSA.71.18",
        "v": 1
      }
    ],
    "section": null
  },
  "PHM.1.10": {
    "text": "ber jeg deg for min sønn, Onesimus, som jeg har født her i mine lenker.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "COL.4.9",
        "v": 9
      },
      {
        "r": "1CO.4.15",
        "v": 8
      },
      {
        "r": "GAL.4.19",
        "v": 7
      },
      {
        "r": "1TI.1.2",
        "v": 7
      },
      {
        "r": "TIT.1.4",
        "v": 6
      },
      {
        "r": "2SA.19.37-38",
        "v": 5
      },
      {
        "r": "2SA.18.5",
        "v": 4
      },
      {
        "r": "2SA.9.1-7",
        "v": 4
      },
      {
        "r": "MRK.9.17",
        "v": 3
      }
    ],
    "section": null
  },
  "PHM.1.11": {
    "text": "Før var han unyttig for deg, men nå er han nyttig både for deg og meg.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2TI.4.11",
        "v": 8
      },
      {
        "r": "JOB.30.1-2",
        "v": 6
      },
      {
        "r": "LUK.15.32",
        "v": 5
      },
      {
        "r": "1PE.2.10",
        "v": 5
      },
      {
        "r": "LUK.17.10",
        "v": 4
      },
      {
        "r": "ROM.3.12",
        "v": 4
      },
      {
        "r": "MAT.25.30",
        "v": 4
      },
      {
        "r": "LUK.15.24",
        "v": 3
      }
    ],
    "section": null
  },
  "PHM.1.12": {
    "text": "Nå sender jeg ham tilbake til deg. Ta du imot han! Det er mitt eget hjerte.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "MAT.6.14-15",
        "v": 4
      },
      {
        "r": "MAT.18.21-35",
        "v": 3
      },
      {
        "r": "JER.31.20",
        "v": 3
      },
      {
        "r": "EPH.4.32",
        "v": 3
      },
      {
        "r": "MRK.11.25",
        "v": 3
      },
      {
        "r": "LUK.15.20",
        "v": 3
      },
      {
        "r": "2SA.16.11",
        "v": 2
      },
      {
        "r": "DEU.13.6",
        "v": 2
      }
    ],
    "section": null
  },
  "PHM.1.13": {
    "text": "Jeg hadde ønsket å beholde ham her hos meg, slik at han i ditt sted kunne ha tjent meg mens jeg er i lenker for evangeliets skyld.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PHP.1.7",
        "v": 4
      },
      {
        "r": "EPH.3.1",
        "v": 4
      },
      {
        "r": "1CO.16.17",
        "v": 3
      },
      {
        "r": "PHP.2.30",
        "v": 2
      },
      {
        "r": "EPH.4.1",
        "v": 2
      },
      {
        "r": "PHM.1.1",
        "v": 2
      }
    ],
    "section": null
  },
  "PHM.1.14": {
    "text": "Men uten ditt samtykke ville jeg ikke gjøre dette, så ikke din godhet skulle være som av tvang, men av fri vilje.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2CO.9.7",
        "v": 8
      },
      {
        "r": "1PE.5.2-3",
        "v": 3
      },
      {
        "r": "1CH.29.17",
        "v": 3
      },
      {
        "r": "PHM.1.8-9",
        "v": 2
      },
      {
        "r": "1CO.9.17",
        "v": 2
      },
      {
        "r": "2CO.8.12",
        "v": 2
      },
      {
        "r": "2CO.9.5",
        "v": 2
      },
      {
        "r": "2CO.1.24",
        "v": 1
      },
      {
        "r": "PSA.110.3",
        "v": 1
      }
    ],
    "section": null
  },
  "PHM.1.15": {
    "text": "Kanskje ble han nettopp derfor skilt fra deg for en stund, for at du kunne få ham igjen til evig eie -",
    "footnotes": [],
    "xrefs": [
      {
        "r": "GEN.50.20",
        "v": 7
      },
      {
        "r": "GEN.45.5-8",
        "v": 4
      },
      {
        "r": "ISA.20.6",
        "v": 2
      },
      {
        "r": "ACT.4.28",
        "v": 1
      }
    ],
    "section": null
  },
  "PHM.1.16": {
    "text": "og da ikke lenger som trell, men som mer enn en trell: som en elsket bror. Slik er det i høy grad for meg, og hvor mye mer da for deg, både i kjødet og i Herren.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "COL.3.22",
        "v": 6
      },
      {
        "r": "MAT.23.8",
        "v": 6
      },
      {
        "r": "1TI.6.2",
        "v": 5
      },
      {
        "r": "1CO.7.22",
        "v": 5
      },
      {
        "r": "EPH.6.5-7",
        "v": 4
      },
      {
        "r": "1PE.1.22-23",
        "v": 3
      },
      {
        "r": "ACT.9.17",
        "v": 2
      },
      {
        "r": "HEB.3.1",
        "v": 2
      },
      {
        "r": "GAL.4.28-29",
        "v": 2
      },
      {
        "r": "1JN.5.1",
        "v": 1
      }
    ],
    "section": null
  },
  "PHM.1.17": {
    "text": "Så sant du holder meg for din medbror i troen, så ta imot ham som meg selv!",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2CO.8.23",
        "v": 8
      },
      {
        "r": "MAT.10.40",
        "v": 6
      },
      {
        "r": "PHM.1.12",
        "v": 4
      },
      {
        "r": "MAT.18.5",
        "v": 3
      },
      {
        "r": "EPH.3.6",
        "v": 2
      },
      {
        "r": "JAS.2.5",
        "v": 2
      },
      {
        "r": "HEB.3.1",
        "v": 2
      },
      {
        "r": "MAT.12.48-50",
        "v": 2
      },
      {
        "r": "ACT.16.15",
        "v": 2
      },
      {
        "r": "MAT.25.40",
        "v": 2
      },
      {
        "r": "1TI.6.2",
        "v": 1
      },
      {
        "r": "HEB.3.14",
        "v": 1
      },
      {
        "r": "PHP.1.7",
        "v": 1
      },
      {
        "r": "1PE.5.1",
        "v": 1
      },
      {
        "r": "1JN.1.3",
        "v": 1
      },
      {
        "r": "PHM.1.10",
        "v": 1
      }
    ],
    "section": null
  },
  "PHM.1.18": {
    "text": "Har han gjort deg noen urett, eller er han deg noe skyldig, så skriv det på min regning!",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ISA.53.4-7",
        "v": 7
      }
    ],
    "section": null
  },
  "PHM.1.19": {
    "text": "Jeg, Paulus, skriver med min egen hånd: Jeg skal betale det! - for ikke å si deg at du til og med skylder meg deg selv!",
    "footnotes": [],
    "xrefs": [
      {
        "r": "GAL.6.11",
        "v": 4
      },
      {
        "r": "GAL.5.2",
        "v": 3
      },
      {
        "r": "1CO.16.21-22",
        "v": 3
      },
      {
        "r": "JAS.5.19-20",
        "v": 2
      },
      {
        "r": "1CO.4.15",
        "v": 2
      },
      {
        "r": "1CO.9.1-2",
        "v": 2
      },
      {
        "r": "2CO.3.2",
        "v": 1
      },
      {
        "r": "TIT.1.4",
        "v": 1
      },
      {
        "r": "1TI.1.2",
        "v": 1
      }
    ],
    "section": null
  },
  "PHM.1.20": {
    "text": "Ja, bror! Måtte jeg nå ha nytte av deg i Herren! Gled mitt hjerte i Kristus.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PHM.1.7",
        "v": 5
      },
      {
        "r": "3JN.1.4",
        "v": 4
      },
      {
        "r": "PHM.1.12",
        "v": 3
      },
      {
        "r": "HEB.13.17",
        "v": 3
      },
      {
        "r": "1TH.2.19-20",
        "v": 2
      },
      {
        "r": "2CO.2.2",
        "v": 2
      },
      {
        "r": "1JN.3.17",
        "v": 2
      },
      {
        "r": "2CO.7.4-7",
        "v": 2
      },
      {
        "r": "2CO.7.13",
        "v": 2
      },
      {
        "r": "PHP.2.1-2",
        "v": 2
      },
      {
        "r": "PHP.4.1",
        "v": 2
      },
      {
        "r": "1TH.3.7-9",
        "v": 2
      },
      {
        "r": "PHP.1.8",
        "v": 2
      }
    ],
    "section": null
  },
  "PHM.1.21": {
    "text": "I tillit til din lydighet skriver jeg til deg. Jeg er viss på at du vil gjøre enda mer enn det jeg ber deg om.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2TH.3.4",
        "v": 5
      },
      {
        "r": "2CO.2.3",
        "v": 4
      },
      {
        "r": "2CO.7.16",
        "v": 3
      },
      {
        "r": "2CO.8.22",
        "v": 2
      },
      {
        "r": "GAL.5.10",
        "v": 2
      }
    ],
    "section": "Hilsener og velsignelse"
  },
  "PHM.1.22": {
    "text": "Og gjør dessuten i stand et gjesterom for meg! For jeg håper at jeg ved deres forbønn skal bli gitt tilbake til dere.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2CO.1.11",
        "v": 5
      },
      {
        "r": "PHP.2.24",
        "v": 5
      },
      {
        "r": "2JN.1.12",
        "v": 3
      },
      {
        "r": "JAS.5.16",
        "v": 3
      },
      {
        "r": "ACT.28.23",
        "v": 3
      },
      {
        "r": "PHP.1.19",
        "v": 3
      },
      {
        "r": "HEB.13.19",
        "v": 2
      },
      {
        "r": "PHP.1.25-26",
        "v": 2
      },
      {
        "r": "ROM.15.30-32",
        "v": 2
      },
      {
        "r": "ROM.15.24",
        "v": 2
      },
      {
        "r": "3JN.1.14",
        "v": 2
      },
      {
        "r": "HEB.13.23",
        "v": 2
      }
    ],
    "section": null
  },
  "PHM.1.23": {
    "text": "Epafras, min medfange i Kristus Jesus, hilser deg.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "COL.1.7",
        "v": 5
      },
      {
        "r": "COL.4.12",
        "v": 4
      },
      {
        "r": "ROM.16.7",
        "v": 4
      },
      {
        "r": "COL.4.10",
        "v": 2
      }
    ],
    "section": null
  },
