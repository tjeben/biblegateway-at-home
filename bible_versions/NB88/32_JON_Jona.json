        "v": 3
      },
      {
        "r": "EZK.3.17",
        "v": 2
      },
      {
        "r": "JER.15.19-21",
        "v": 2
      },
      {
        "r": "MAT.3.8",
        "v": 2
      },
      {
        "r": "ZEP.2.13-15",
        "v": 2
      },
      {
        "r": "JHN.5.14",
        "v": 2
      }
    ],
    "section": null
  },
  "JON.3.3": {
    "text": "Og Jona sto opp og gikk til Ninive, som Herren hadde sagt. Ninive var en stor by for Gud, tre dagsreiser lang.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PSA.80.10",
        "v": 1
      },
      {
        "r": "MAT.21.28-29",
        "v": 1
      },
      {
        "r": "GEN.22.3",
        "v": 1
      }
    ],
    "section": null
  },
  "JON.3.4": {
    "text": "Jona gikk en dagsreise inn i byen og ropte: Om førti dager skal Ninive bli ødelagt.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "DEU.18.22",
        "v": 8
      },
      {
        "r": "JER.18.7-10",
        "v": 7
      },
      {
        "r": "2KI.20.1",
        "v": 3
      },
      {
        "r": "2KI.20.6",
        "v": 3
      },
      {
        "r": "JON.3.10",
        "v": 3
      }
    ],
    "section": null
  },
  "JON.3.5": {
    "text": "Da trodde folket i Ninive på Gud. De ropte ut en faste og kledde seg i sekk, både store og små.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "LUK.11.32",
        "v": 11
      },
      {
        "r": "DAN.9.3",
