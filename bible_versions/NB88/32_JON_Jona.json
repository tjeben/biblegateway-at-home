        "v": 4
      },
      {
        "r": "ACT.3.19",
        "v": 3
      },
      {
        "r": "JON.1.14",
        "v": 3
      },
      {
        "r": "ISA.1.16-19",
        "v": 3
      },
      {
        "r": "EZK.18.21-24",
        "v": 3
      },
      {
        "r": "ISA.58.6",
        "v": 2
      },
      {
