        "v": 3
      },
      {
        "r": "PSA.30.6-7",
        "v": 3
      }
    ],
    "section": null
  },
  "JON.4.8": {
    "text": "Og da solen sto opp, sendte Gud en het østavind. Og solen stakk Jona i hodet så han var helt forkommen. Da ønsket han seg døden, og sa: Jeg vil heller dø enn leve!",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PSA.121.6",
        "v": 5
      },
      {
        "r": "JON.4.3",
        "v": 5
