      },
      {
        "r": "JER.42.1",
        "v": 1
      }
    ],
    "section": "Ninives innbyggere omvender seg"
  },
  "JON.3.6": {
    "text": "Da saken kom Ninives konge for øre, sto han opp fra sin trone og la kappen av seg. Og han svøpte seg i sekk og satte seg i støvet.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JAS.4.6-10",
        "v": 6
      },
      {
        "r": "EST.4.1-4",
        "v": 6
      },
      {
        "r": "JOB.2.8",
        "v": 4
