      {
        "r": "JON.4.4",
        "v": 4
      },
      {
        "r": "LUK.7.39",
        "v": 2
      },
      {
        "r": "JAS.4.5-6",
        "v": 2
      },
      {
        "r": "ACT.13.46",
        "v": 1
      }
    ],
    "section": "Jonas harme og Guds nåde"
  },
  "JON.4.2": {
    "text": "Han ba til Herren og sa: Å Herre! Var det ikke det jeg sa da jeg ennå var i mitt hjemland! Derfor flyktet jeg til Tarsis så fort jeg kunne. For jeg visste at du er en nådig og barmhjertig Gud, langmodig og rik på miskunn, så du angrer det onde.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PSA.86.15",
        "v": 31
      },
      {
        "r": "EXO.34.6-7",
        "v": 30
