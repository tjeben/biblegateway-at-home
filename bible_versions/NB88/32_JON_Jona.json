        "v": 6
      },
      {
        "r": "JOL.2.13",
        "v": 6
      },
      {
        "r": "JON.4.2",
        "v": 5
      }
    ],
    "section": null
  },
  "JON.4.1": {
    "text": "Men dette syntes Jona meget ille om, og han ble harm.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JON.4.9",
        "v": 6
      },
      {
        "r": "LUK.15.28",
        "v": 6
      },
      {
        "r": "MAT.20.15",
        "v": 5
