    "section": null
  },
  "JON.4.5": {
    "text": "Jona var gått ut av byen, og hadde satt seg østafor den. Der hadde han laget seg en løvhytte og satt i skyggen under den for å se hvordan det gikk med byen.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "1KI.19.9",
        "v": 3
      },
      {
        "r": "1KI.19.13",
