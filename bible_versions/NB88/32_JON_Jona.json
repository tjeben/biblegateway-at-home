      },
      {
        "r": "GEN.1.7",
        "v": 3
      }
    ],
    "section": null
  },
  "JON.2.11": {
    "text": "Da talte Herren til fisken, og den spydde Jona opp på det tørre land.",
    "footnotes": [],
    "xrefs": [],
    "section": null
  },
  "JON.3.1": {
    "text": "Og Herrens ord kom til Jona for andre gang, og det lød så:",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JON.1.1",
        "v": 3
      }
    ],
    "section": "Jona går til Ninive"
  },
  "JON.3.2": {
    "text": "Stå opp, gå til Ninive, den store byen, og rop ut i den det budskapet jeg taler til deg.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JER.1.17",
        "v": 5
      },
      {
        "r": "EZK.2.7",
        "v": 5
