        "v": 1
      }
    ],
    "section": null
  },
  "JON.3.7": {
    "text": "Han lot rope ut i Ninive: Etter påbud av kongen og hans stormenn, skal verken mennesker eller dyr, storfe eller småfe, spise noen ting! De skal ikke smake mat og ikke drikke vann.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2CH.20.3",
        "v": 6
      },
      {
        "r": "JOL.2.15-16",
        "v": 5
      },
      {
        "r": "JON.3.5",
        "v": 5
      },
      {
        "r": "JOL.1.18",
        "v": 5
      },
      {
        "r": "EZR.8.21",
        "v": 4
      },
      {
        "r": "ROM.8.20-22",
        "v": 3
      }
    ],
    "section": null
  },
  "JON.3.8": {
    "text": "Men de skal svøpe seg i sekk, både mennesker og dyr. De skal rope til Gud av all makt, og vende om, hver fra sin onde vei og fra den urett som henger ved deres hender.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JON.1.6",
        "v": 4
      },
      {
        "r": "ISA.55.6-7",
        "v": 4
