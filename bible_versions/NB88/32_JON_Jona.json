    "section": null
  },
  "JON.4.9": {
    "text": "Men Gud sa til Jona: Er det med rette du er så harm for kikajontreets skyld? Han svarte: Ja, med rette, jeg er så harm at jeg kunne dø.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "GEN.4.5-14",
        "v": 2
