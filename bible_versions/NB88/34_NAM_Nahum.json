        "v": 4
      },
      {
        "r": "PSA.38.5-7",
        "v": 4
      },
      {
        "r": "1CO.4.9",
        "v": 3
      },
      {
        "r": "HEB.10.33",
        "v": 3
      },
      {
        "r": "NAM.1.14",
        "v": 3
      },
      {
        "r": "JOB.30.8",
        "v": 3
      },
      {
        "r": "JUD.1.7",
        "v": 2
      },
      {
        "r": "ISA.14.16-19",
        "v": 2
      },
      {
        "r": "1CO.4.13",
        "v": 2
      },
      {
        "r": "LAM.3.16",
        "v": 2
      },
      {
