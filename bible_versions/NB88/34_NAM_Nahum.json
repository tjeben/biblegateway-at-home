        "r": "ISA.60.18-20",
        "v": 1
      },
      {
        "r": "ISA.30.28-33",
        "v": 1
      }
    ],
    "section": null
  },
  "NAM.1.13": {
    "text": "Nå vil jeg bryte det åket han la på deg og rive i stykker dine lenker.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ISA.10.27",
        "v": 10
      },
      {
        "r": "ISA.9.4",
        "v": 9
      },
      {
        "r": "PSA.107.14",
        "v": 7
      },
      {
        "r": "JER.2.20",
        "v": 7
      },
      {
        "r": "ISA.14.25",
        "v": 6
      },
      {
        "r": "JER.5.5",
        "v": 5
      },
      {
        "r": "MIC.5.5-6",
        "v": 4
      }
    ],
    "section": null
  },
  "NAM.1.14": {
    "text": "Men om deg har Herren gitt denne befalingen: Det skal ikke mer bli født noen som bærer ditt navn. Jeg vil utrydde både utskårne og støpte gudebilder fra din guds hus. Jeg vil gjøre i stand en grav til deg, for du er funnet for lett.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PSA.109.13",
        "v": 6
      },
      {
        "r": "MIC.5.13",
        "v": 5
      },
      {
        "r": "ISA.46.1-2",
        "v": 4
      },
      {
        "r": "PRO.10.7",
        "v": 4
      },
      {
        "r": "2KI.19.37",
        "v": 3
      },
      {
        "r": "EZK.32.22-23",
        "v": 3
      },
      {
        "r": "PSA.71.3",
        "v": 3
      },
      {
        "r": "2CH.32.21",
        "v": 2
      },
      {
        "r": "NAM.3.4-6",
        "v": 2
      },
      {
        "r": "JER.50.2",
        "v": 2
      },
      {
        "r": "ISA.14.20-22",
        "v": 2
      },
      {
        "r": "ISA.33.13",
        "v": 2
      },
      {
        "r": "ISA.19.1",
        "v": 2
      },
      {
        "r": "EXO.12.12",
        "v": 2
      },
      {
        "r": "1SA.3.13",
        "v": 2
      },
      {
        "r": "LEV.26.30",
        "v": 2
      },
      {
        "r": "DAN.11.21",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.1": {
    "text": "Se på fjellene hans føtter som bringer godt budskap - som forkynner fred! - Hold dine høytider, Juda, innfri dine løfter! For aldri mer skal den fordervede gå igjennom ditt land, han er helt tilintetgjort.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JOL.3.9-11",
        "v": 9
      },
      {
        "r": "2CH.25.8",
        "v": 8
      },
      {
        "r": "JER.51.20-23",
        "v": 6
      },
      {
        "r": "JER.51.11-12",
        "v": 5
      },
      {
        "r": "JER.50.23",
        "v": 4
      },
      {
        "r": "JER.46.3-10",
        "v": 3
      },
      {
        "r": "ISA.14.6",
        "v": 2
      },
      {
        "r": "NAM.3.14-15",
        "v": 1
      },
      {
        "r": "JER.25.9",
        "v": 0
      }
    ],
    "section": null
  },
  "NAM.2.2": {
    "text": "Det drar opp mot deg en som vil spre deg til alle kanter. Hold vakt i borgen! Se ut på veien! Spenn beltet om livet, samle all din kraft.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PSA.80.12-13",
        "v": 5
      },
      {
        "r": "EZK.37.23",
        "v": 5
      },
      {
        "r": "ZEP.3.11",
        "v": 4
      },
      {
        "r": "ISA.60.15",
        "v": 3
      },
      {
        "r": "HOS.10.1",
        "v": 2
      },
      {
        "r": "ISA.10.5-12",
        "v": 2
      },
      {
        "r": "JER.25.29",
        "v": 2
      },
      {
        "r": "JER.49.9",
        "v": 2
      },
      {
        "r": "GEN.49.22-23",
        "v": 2
      }
    ],
    "section": "Ninive blir beleiret, inntatt og plyndret"
  },
  "NAM.2.3": {
    "text": "Herren vil føre tilbake Jakobs høyhet og Israels høyhet. For ransmenn har plyndret dem og ødelagt deres vintrær.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "EZK.23.14-15",
        "v": 4
      },
      {
        "r": "ISA.63.1-3",
        "v": 3
      },
      {
        "r": "ZEC.11.2",
        "v": 2
      },
      {
        "r": "REV.6.4",
        "v": 2
      },
      {
        "r": "REV.12.3",
        "v": 2
      },
      {
        "r": "ISA.14.8",
        "v": 2
      },
      {
        "r": "ZEC.6.2",
        "v": 2
      },
      {
        "r": "ZEC.1.8",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.4": {
    "text": "Hans stridskjemper har røde skjold, krigsmennene er kledd i skarlagen, vognene er kledd i flammende stål den dagen han stiller dem opp, og spydene svinges.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JER.4.13",
        "v": 4
      },
      {
        "r": "NAM.3.2-3",
        "v": 3
      },
      {
        "r": "EZK.26.10",
        "v": 3
      },
      {
        "r": "ISA.66.15",
        "v": 3
      },
      {
        "r": "ISA.37.24",
        "v": 2
      },
      {
        "r": "DAN.11.40",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.5": {
    "text": "På gatene raser vognene av sted, over torgene farer de i susende fart. De ser ut som fakler, de farer fram og tilbake som lyn.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JER.46.12",
        "v": 5
      },
      {
        "r": "JER.51.27-28",
        "v": 2
      },
      {
        "r": "JER.50.29",
        "v": 2
      },
      {
        "r": "ISA.5.27",
        "v": 2
      },
      {
        "r": "NAM.3.3",
        "v": 2
      },
      {
        "r": "NAM.3.18",
        "v": 2
      },
      {
        "r": "ISA.21.5",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.6": {
    "text": "Han kaller på sine stormenn, men de snubler under sin gang, de haster av sted til bymuren, men skjoldtaket er satt opp.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ISA.45.1-2",
        "v": 3
      },
      {
        "r": "2PE.3.10-11",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.7": {
    "text": "Portene ut mot elven blir åpnet, palasset forgår av angst.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ISA.59.11",
        "v": 5
      },
      {
        "r": "ISA.38.14",
        "v": 5
      },
      {
        "r": "LUK.23.48",
        "v": 2
      },
      {
        "r": "ISA.32.12",
        "v": 2
      },
      {
        "r": "LUK.23.27",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.8": {
    "text": "Hun blir stilt fram, hun blir avkledd og ført bort. Hennes piker klager, kurrer som duer og slår seg for brystet.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "REV.17.15",
        "v": 2
      },
      {
        "r": "REV.17.1",
        "v": 2
      },
      {
        "r": "JER.51.30",
        "v": 2
      },
      {
        "r": "GEN.10.11",
        "v": 2
      },
      {
        "r": "JER.50.16",
        "v": 2
      },
      {
        "r": "ISA.48.20",
        "v": 2
      },
      {
        "r": "JER.51.13",
        "v": 2
      },
      {
        "r": "ISA.47.13",
        "v": 2
      },
      {
        "r": "ISA.13.14",
        "v": 2
      },
      {
        "r": "NAM.3.17",
        "v": 2
      },
      {
        "r": "JER.46.5",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.9": {
    "text": "Ninive har alle sine dager vært som en dam full av vann. Men nå flykter de. Stans, stans! Men ingen vender om.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JER.51.56",
        "v": 2
      },
      {
        "r": "DAN.11.8",
        "v": 2
      },
      {
        "r": "2CH.36.10",
        "v": 2
      },
      {
        "r": "JER.25.34",
        "v": 2
      },
      {
        "r": "ISA.33.4",
        "v": 2
      },
      {
        "r": "NAM.2.12-13",
        "v": 2
      },
      {
        "r": "EZK.26.12",
        "v": 2
      },
      {
        "r": "ISA.33.1",
        "v": 1
      }
    ],
    "section": null
  },
  "NAM.2.10": {
    "text": "Røv sølv! Røv gull! For her er ingen ende på skattene, en overflod av alle slags kostbare ting.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PSA.22.14",
        "v": 6
      },
      {
        "r": "JOL.2.6",
        "v": 6
      },
      {
        "r": "DAN.5.6",
        "v": 6
      },
      {
        "r": "JER.30.6",
        "v": 4
      },
      {
        "r": "ISA.13.7-8",
        "v": 4
      },
      {
        "r": "ZEP.2.13-15",
        "v": 3
      },
      {
        "r": "ISA.21.3",
        "v": 3
      },
      {
        "r": "ISA.24.1",
        "v": 3
      },
      {
        "r": "ISA.14.23",
        "v": 2
      },
      {
        "r": "JOS.2.11",
        "v": 2
      },
      {
        "r": "REV.18.21-23",
        "v": 2
      },
      {
        "r": "JER.51.62",
        "v": 2
      },
      {
        "r": "JER.4.23-26",
        "v": 2
      },
      {
        "r": "NAM.3.7",
        "v": 2
      },
      {
        "r": "ISA.13.19-22",
        "v": 2
      },
      {
        "r": "ZEP.3.6",
        "v": 2
      },
      {
        "r": "ISA.34.10-15",
        "v": 2
      },
      {
        "r": "GEN.1.2",
        "v": 1
      }
    ],
    "section": null
  },
  "NAM.2.11": {
    "text": "Tomt! tømt! uttømt! - forferdede hjerter og vaklende knær. Alle hofter skjelver. Hvert ansikt er blussende rødt.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ISA.5.29",
        "v": 5
      },
      {
        "r": "JER.2.15",
        "v": 3
      },
      {
        "r": "JER.50.44",
        "v": 2
      },
      {
        "r": "JER.50.17",
        "v": 2
      },
      {
        "r": "ZEP.3.3",
        "v": 2
      },
      {
        "r": "GEN.49.9",
        "v": 2
      },
      {
        "r": "EZK.19.2-8",
        "v": 2
      },
      {
        "r": "NAM.3.1",
        "v": 2
      },
      {
        "r": "JOB.4.10-11",
        "v": 2
      },
      {
        "r": "ISA.31.4",
        "v": 2
      },
      {
        "r": "JER.4.7",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.12": {
    "text": "Hvor er løvens bolig? - stedet hvor ungløvene fortærte sitt bytte, hvor løven og løvinnen holdt til, og løveungen. Der var det ingen som skremte dem.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JER.51.34",
        "v": 3
      },
      {
        "r": "ISA.10.6-14",
        "v": 2
      },
      {
        "r": "PSA.17.12",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.13": {
    "text": "Løven røvet til dens unger hadde fått nok, den drepte for sine løvinner. Den fylte sine huler med rov, sin bolig med det den hadde revet i stykker.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JER.21.13",
        "v": 6
      },
      {
        "r": "PSA.46.9",
        "v": 6
      },
      {
        "r": "NAM.3.5",
        "v": 6
      },
      {
        "r": "2KI.19.23",
        "v": 5
      },
      {
        "r": "JOS.11.9",
        "v": 3
      },
      {
        "r": "2KI.19.9",
        "v": 3
      },
      {
        "r": "NAM.3.1",
        "v": 3
      },
      {
        "r": "EZK.5.8",
        "v": 3
      },
      {
        "r": "ISA.49.24-25",
        "v": 3
      },
      {
        "r": "2KI.18.19",
        "v": 2
      },
      {
        "r": "ISA.33.1-4",
        "v": 2
      },
      {
        "r": "EZK.39.1",
        "v": 2
      },
      {
        "r": "EZK.29.10",
        "v": 2
      },
      {
        "r": "NAM.3.12",
        "v": 2
      },
      {
        "r": "2CH.32.9-16",
        "v": 2
      },
      {
        "r": "2CH.32.19",
        "v": 2
      },
      {
        "r": "JER.51.25",
        "v": 2
      },
      {
        "r": "EZK.28.22",
        "v": 2
      },
      {
        "r": "2KI.18.17",
        "v": 2
      },
      {
        "r": "ISA.31.8-9",
        "v": 2
      },
      {
        "r": "ISA.37.36-38",
        "v": 2
      },
      {
        "r": "JER.50.31",
        "v": 2
      },
      {
        "r": "EZK.35.3",
        "v": 2
      },
      {
        "r": "EZK.29.3",
        "v": 2
      },
      {
        "r": "2KI.18.27-35",
        "v": 2
      },
      {
        "r": "EZK.26.3",
        "v": 2
      },
      {
        "r": "EZK.38.3",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.14": {
    "text": "Se, jeg kommer over deg, sier Herren, hærskarenes Gud. Jeg vil brenne dine vogner, så de går opp i røk. Dine ungløver skal sverdet fortære. Jeg vil utrydde ditt rov fra jorden, og dine sendebuds røst skal aldri mer bli hørt.",
    "footnotes": [],
    "xrefs": [],
    "section": null
  },
  "NAM.3.1": {
    "text": "Ve blodbyen! - helt igjennom full av løgn og vold. Aldri holder den opp med å røve.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ZEP.3.1-3",
        "v": 6
      },
      {
        "r": "HAB.2.12",
        "v": 6
      },
      {
        "r": "EZK.22.2-3",
        "v": 5
      },
      {
        "r": "HOS.4.2",
        "v": 5
      },
      {
        "r": "EZK.24.6-9",
        "v": 5
      },
      {
        "r": "NAM.2.12",
        "v": 4
      },
      {
        "r": "ISA.42.24",
        "v": 2
      },
      {
        "r": "ISA.17.14",
        "v": 2
      },
      {
        "r": "ISA.24.9",
        "v": 1
      }
    ],
    "section": "Ve Ninive, blodbyen!"
  },
  "NAM.3.2": {
    "text": "Svepesmell og larmende hjul, galopperende hester og hoppende vogner,",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JER.47.3",
        "v": 5
      },
      {
        "r": "NAM.2.3-4",
        "v": 4
      },
      {
        "r": "JOB.39.22-25",
        "v": 3
      },
      {
        "r": "JDG.5.22",
        "v": 3
      },
      {
        "r": "ISA.9.5",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.3.3": {
    "text": "fremstormende ryttere, lynende sverd og blinkende spyd, drepte i mengde og dynger av lik. Det er ingen ende på døde kropper - en snubler over deres døde kropper.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "HAB.3.11",
        "v": 5
      },
      {
        "r": "EZK.39.4",
        "v": 5
      },
      {
        "r": "ISA.34.3",
        "v": 4
      },
      {
        "r": "ISA.37.36",
        "v": 4
      },
      {
        "r": "GEN.3.24",
        "v": 3
      },
      {
        "r": "EZK.31.3-13",
        "v": 2
      },
      {
        "r": "2KI.19.35",
        "v": 2
      },
      {
        "r": "NAM.2.4",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.3.4": {
    "text": "Dette er gjengjeldelse for alt det horeri hun drev, hun den vakre trolldommens mester. Hun solgte folkeslag ved sitt hor, hele stammer ved sine trolldomskunster.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ISA.47.9",
        "v": 7
      },
      {
        "r": "ISA.47.12-13",
        "v": 5
      },
      {
        "r": "REV.18.23",
        "v": 3
      },
      {
        "r": "EZK.16.25-29",
        "v": 3
      },
      {
        "r": "REV.18.2-3",
        "v": 3
      },
      {
        "r": "REV.17.1-5",
        "v": 3
      },
      {
        "r": "REV.18.9",
        "v": 3
      },
      {
        "r": "ISA.23.15-17",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.3.5": {
    "text": "Se, jeg kommer over deg, sier Herren, hærskarenes Gud. Jeg vil dra ditt skjørt opp over ditt ansikt og blotte deg, jeg vil vise folkeslagene din nakenhet og rikene din skam.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JER.13.26",
        "v": 8
      },
      {
        "r": "EZK.23.29",
        "v": 6
      },
      {
        "r": "JER.13.22",
        "v": 6
      },
      {
        "r": "ISA.47.2-3",
        "v": 5
      },
      {
        "r": "NAM.2.13",
        "v": 5
      },
      {
        "r": "EZK.16.37",
        "v": 5
      },
      {
        "r": "HAB.2.16",
        "v": 4
      },
      {
        "r": "EZK.23.25",
        "v": 2
      },
      {
        "r": "MIC.1.11",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.3.6": {
    "text": "Jeg vil kaste avskyelig smuss på deg og vanære deg og gjøre deg til et skuespill.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "MAL.2.9",
        "v": 5
      },
      {
        "r": "JER.51.37",
        "v": 4
      },
