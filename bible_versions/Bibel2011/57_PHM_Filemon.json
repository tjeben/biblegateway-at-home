        "v": 3
      },
      {
        "r": "2TI.1.8",
        "v": 3
      },
      {
        "r": "1TH.3.2",
        "v": 3
      },
      {
        "r": "EPH.4.1",
        "v": 3
      },
      {
        "r": "PHM.1.24",
        "v": 2
      },
      {
        "r": "EPH.6.20",
        "v": 2
      },
      {
        "r": "2TH.1.1",
        "v": 2
      }
    ],
    "section": "Hilsen"
  },
  "PHM.1.2": {
    "text": "vår søster Appia, vår stridskamerat Arkippos og menigheten som samles i ditt hus:",
    "footnotes": [
      {
        "marker": "#",
        "text": "muligens Filemons ektefelle."
      }
    ],
    "xrefs": [
      {
        "r": "PHP.2.25",
        "v": 7
      },
      {
        "r": "COL.4.17",
        "v": 6
      },
      {
        "r": "ROM.16.5",
        "v": 6
      },
      {
        "r": "COL.4.15",
        "v": 4
      },
      {
        "r": "2TI.2.3-4",
        "v": 3
      },
      {
        "r": "1CO.16.19",
        "v": 3
      }
    ],
    "section": null
  },
  "PHM.1.3": {
    "text": "Nåde være med dere og fred fra Gud, vår Far, og Herren Jesus Kristus!",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ROM.1.7",
        "v": 5
      },
      {
        "r": "EPH.1.2",
        "v": 4
      },
      {
        "r": "2CO.13.14",
        "v": 3
      }
    ],
    "section": null
  },
  "PHM.1.4": {
    "text": "Jeg takker alltid min Gud når jeg husker på deg i mine bønner.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ROM.1.8",
        "v": 7
      },
      {
        "r": "EPH.1.16",
        "v": 6
      },
      {
        "r": "COL.1.3",
        "v": 5
      },
      {
        "r": "PHP.1.3",
        "v": 5
      },
      {
        "r": "2TH.1.3",
        "v": 4
      },
      {
        "r": "1TH.1.2",
        "v": 4
      },
      {
        "r": "2TI.1.3",
        "v": 2
      }
    ],
    "section": "Filemons tro og kjærlighet"
  },
  "PHM.1.5": {
    "text": "For jeg hører om kjærligheten du har til alle de hellige, og om din tro på Herren Jesus.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "COL.1.4",
        "v": 10
      },
      {
        "r": "EPH.1.15",
        "v": 7
      },
      {
        "r": "PSA.16.3",
        "v": 3
      },
      {
        "r": "1CO.16.1",
        "v": 3
      },
      {
        "r": "1JN.5.1-2",
        "v": 3
      },
      {
        "r": "1JN.3.23",
        "v": 2
      },
      {
        "r": "PHM.1.7",
        "v": 2
      },
      {
        "r": "GAL.5.6",
        "v": 2
      },
      {
        "r": "ROM.15.25-26",
        "v": 2
      },
      {
        "r": "ROM.12.13",
        "v": 2
      },
      {
        "r": "ACT.9.39-41",
        "v": 1
      }
    ],
    "section": null
  },
  "PHM.1.6": {
    "text": "Jeg ber om at den tro du har felles med oss, må være virksom og gi deg større innsikt i alt det gode vi har i Kristus.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2PE.1.8",
        "v": 13
      },
      {
        "r": "PHP.1.9-11",
        "v": 13
      },
      {
        "r": "COL.1.9",
        "v": 8
      },
      {
        "r": "1PE.1.5-8",
        "v": 5
      },
      {
        "r": "MAT.5.16",
        "v": 5
      },
      {
        "r": "TIT.3.14",
        "v": 4
      },
      {
        "r": "2CO.9.12-14",
        "v": 4
      },
      {
        "r": "1PE.2.12",
        "v": 4
      },
      {
        "r": "JAS.2.17",
        "v": 4
      },
      {
        "r": "JAS.2.14",
        "v": 4
      },
      {
        "r": "HEB.6.10",
        "v": 3
      },
      {
        "r": "1CO.14.25",
        "v": 3
      },
      {
        "r": "PHP.4.8",
        "v": 3
      },
      {
        "r": "1PE.3.16",
