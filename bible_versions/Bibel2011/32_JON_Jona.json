        "v": 8
      },
      {
        "r": "AMO.7.3",
        "v": 8
      },
      {
        "r": "JOB.33.27-28",
        "v": 6
      },
      {
        "r": "JOL.2.13",
        "v": 6
      },
      {
        "r": "JON.4.2",
        "v": 5
      }
    ],
    "section": null
  },
  "JON.4.1": {
    "text": "Men dette mislikte Jona sterkt, og han ble sint.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JON.4.9",
        "v": 6
      },
      {
        "r": "LUK.15.28",
        "v": 6
      },
      {
        "r": "MAT.20.15",
        "v": 5
      },
      {
        "r": "JON.4.4",
        "v": 4
      },
      {
        "r": "LUK.7.39",
        "v": 2
      },
      {
        "r": "JAS.4.5-6",
        "v": 2
      },
      {
        "r": "ACT.13.46",
        "v": 1
      }
    ],
    "section": "Jonas harme og Guds nåde"
  },
  "JON.4.2": {
    "text": "Han ba til Herren: «Herre! Var det ikke det jeg sa da jeg var i mitt eget land? Derfor ville jeg skynde meg og flykte til Tarsis. For jeg vet at du er en nådig og barmhjertig Gud. Du er sen til vrede og rik på miskunn, så du angrer ulykken.",
    "footnotes": [
      {
        "marker": "#",
        "text": ">1,3."
      }
    ],
    "xrefs": [
      {
        "r": "PSA.86.15",
        "v": 31
      },
