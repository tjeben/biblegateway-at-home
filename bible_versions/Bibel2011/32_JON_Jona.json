    ],
    "section": null
  },
  "JON.1.12": {
    "text": "Han svarte: «Løft meg opp og kast meg i havet, så vil det slutte å rase. For jeg vet at det er min skyld at den sterke stormen har rammet dere.»",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2SA.24.17",
        "v": 7
