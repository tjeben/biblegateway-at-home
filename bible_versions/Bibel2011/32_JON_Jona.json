  "JON.1.11": {
    "text": "«Hva skal vi gjøre med deg», sa de, «så havet kan falle til ro omkring oss?» For stormen på havet ble sterkere og sterkere.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "1SA.6.2-3",
        "v": 2
      },
      {
        "r": "MIC.6.6-7",
