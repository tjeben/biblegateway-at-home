      },
      {
        "r": "GEN.1.7",
        "v": 3
      }
    ],
    "section": null
  },
  "JON.2.11": {
    "text": "Da talte Herren til fisken, og den spydde Jona opp på tørt land.",
    "footnotes": [],
    "xrefs": [],
    "section": null
  },
  "JON.3.1": {
    "text": "Herrens ord kom til Jona for andre gang:",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JON.1.1",
        "v": 3
      }
    ],
    "section": "Jona i Ninive"
  },
  "JON.3.2": {
    "text": "«Stå opp og gå til storbyen Ninive! Det budskapet jeg gir deg, skal du rope ut over byen.»",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JER.1.17",
        "v": 5
      },
      {
        "r": "EZK.2.7",
        "v": 5
      },
      {
        "r": "JON.1.2",
        "v": 3
      },
      {
        "r": "JON.3.3",
        "v": 3
      },
      {
        "r": "EZK.3.17",
        "v": 2
      },
      {
        "r": "JER.15.19-21",
        "v": 2
      },
      {
        "r": "MAT.3.8",
        "v": 2
      },
      {
        "r": "ZEP.2.13-15",
        "v": 2
      },
      {
        "r": "JHN.5.14",
        "v": 2
      }
    ],
    "section": null
  },
  "JON.3.3": {
    "text": "Jona sto opp og gikk til Ninive, slik Herren hadde sagt. Men Ninive var en stor by for Gud, tre dagsreiser lang.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PSA.80.10",
        "v": 1
      },
      {
        "r": "MAT.21.28-29",
        "v": 1
      },
      {
        "r": "GEN.22.3",
        "v": 1
      }
    ],
    "section": null
  },
  "JON.3.4": {
    "text": "Jona begynte å gå innover i byen, og da han hadde gått en dagsreise, ropte han: «Ennå førti dager, og så skal Ninive bli ødelagt!»",
    "footnotes": [],
    "xrefs": [
      {
        "r": "DEU.18.22",
        "v": 8
      },
      {
        "r": "JER.18.7-10",
        "v": 7
      },
      {
        "r": "2KI.20.1",
        "v": 3
      },
      {
        "r": "2KI.20.6",
        "v": 3
      },
      {
        "r": "JON.3.10",
        "v": 3
      }
    ],
    "section": null
  },
  "JON.3.5": {
    "text": "Da trodde folket i Ninive på Gud. De ropte ut en faste og kledde seg i sekkestrie, både store og små.",
    "footnotes": [
      {
        "marker": "#",
        "text": ""
      }
    ],
    "xrefs": [
      {
        "r": "LUK.11.32",
        "v": 11
      },
      {
        "r": "DAN.9.3",
        "v": 8
      },
      {
        "r": "JOL.2.12-17",
        "v": 7
      },
      {
        "r": "MAT.12.41",
        "v": 7
      },
      {
        "r": "2CH.20.3",
        "v": 5
      },
      {
        "r": "JOL.1.14",
        "v": 5
      },
      {
        "r": "EXO.9.18-21",
        "v": 3
      },
      {
        "r": "HEB.11.1",
        "v": 2
      },
      {
        "r": "ACT.27.25",
        "v": 2
      },
      {
        "r": "JER.31.34",
        "v": 2
      },
      {
        "r": "JER.36.9",
        "v": 2
