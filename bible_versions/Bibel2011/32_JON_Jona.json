  "JON.4.6": {
    "text": "Da lot Herren Gud en ricinus-busk vokse opp over Jona for å kaste skygge over hodet hans og fri ham fra mismotet. Jona gledet seg stort over busken.",
    "footnotes": [
      {
        "marker": "#",
        "text": "Det hebr. ordet kikajon betegner antakelig ricinus-planten, en buskvekst med store blader."
      }
    ],
