  "JON.2.10": {
    "text": "Men jeg vil ofre til deg med takkesang. Det jeg har lovet, vil jeg holde. Frelsen kommer fra Herren.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "MAT.8.26-27",
        "v": 10
      },
      {
        "r": "PSA.33.9",
