  "JON.1.13": {
    "text": "Mennene rodde på for å komme tilbake til land, men de greide det ikke. For det stormet sterkere og sterkere mot dem på havet.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PRO.21.30",
        "v": 6
      },
      {
        "r": "JOB.34.29",
        "v": 3
      }
    ],
    "section": null
  },
  "JON.1.14": {
    "text": "Da ropte de til Herren: «Herre! La ikke oss gå under fordi denne mannen mister livet. La ikke uskyldig blod komme over oss. For du, Herre, har gjort som du ville.»",
