  },
  "JON.2.8": {
    "text": "Da livet mitt ebbet ut, husket jeg på Herren, og bønnen min nådde til deg, til ditt hellige tempel.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PSA.31.6",
