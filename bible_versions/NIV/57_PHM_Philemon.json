    "text": "I do wish, brother, that I may have some benefit from you in the Lord; refresh my heart in Christ.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PHM.1.7",
        "v": 5
      },
      {
        "r": "3JN.1.4",
        "v": 4
      },
      {
        "r": "PHM.1.12",
        "v": 3
      },
      {
        "r": "HEB.13.17",
        "v": 3
      },
      {
        "r": "1TH.2.19-20",
        "v": 2
      },
      {
        "r": "2CO.2.2",
        "v": 2
      },
      {
        "r": "1JN.3.17",
        "v": 2
      },
      {
        "r": "2CO.7.4-7",
        "v": 2
      },
      {
        "r": "2CO.7.13",
        "v": 2
      },
      {
        "r": "PHP.2.1-2",
        "v": 2
      },
      {
        "r": "PHP.4.1",
        "v": 2
      },
      {
        "r": "1TH.3.7-9",
        "v": 2
      },
      {
        "r": "PHP.1.8",
        "v": 2
      }
    ],
    "section": null
  },
  "PHM.1.21": {
    "text": "Confident of your obedience, I write to you, knowing that you will do even more than I ask.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2TH.3.4",
        "v": 5
      },
      {
        "r": "2CO.2.3",
        "v": 4
      },
      {
        "r": "2CO.7.16",
        "v": 3
      },
      {
        "r": "2CO.8.22",
        "v": 2
      },
      {
        "r": "GAL.5.10",
        "v": 2
      }
    ],
    "section": null
  },
  "PHM.1.22": {
    "text": "And one thing more: Prepare a guest room for me, because I hope to be restored to you in answer to your prayers.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2CO.1.11",
        "v": 5
      },
      {
        "r": "PHP.2.24",
        "v": 5
      },
      {
        "r": "2JN.1.12",
        "v": 3
      },
      {
        "r": "JAS.5.16",
        "v": 3
      },
      {
        "r": "ACT.28.23",
        "v": 3
      },
      {
        "r": "PHP.1.19",
        "v": 3
      },
      {
        "r": "HEB.13.19",
        "v": 2
      },
      {
        "r": "PHP.1.25-26",
        "v": 2
      },
      {
        "r": "ROM.15.30-32",
        "v": 2
      },
      {
        "r": "ROM.15.24",
        "v": 2
      },
      {
        "r": "3JN.1.14",
        "v": 2
      },
      {
        "r": "HEB.13.23",
        "v": 2
      }
    ],
    "section": null
  },
