    "footnotes": [],
    "xrefs": [
      {
        "r": "COL.1.7",
        "v": 5
      },
      {
        "r": "COL.4.12",
        "v": 4
      },
      {
        "r": "ROM.16.7",
        "v": 4
      },
      {
        "r": "COL.4.10",
        "v": 2
      }
    ],
    "section": null
  },
