        "v": 6
      },
      {
        "r": "ACT.15.37-39",
        "v": 4
      },
      {
        "r": "ACT.12.12",
        "v": 4
      },
      {
        "r": "ACT.19.29",
        "v": 4
      },
      {
        "r": "PHM.1.1-2",
        "v": 3
      },
      {
        "r": "ACT.12.25",
        "v": 3
      },
      {
        "r": "ACT.27.2",
        "v": 3
      },
      {
        "r": "PHP.4.3",
        "v": 2
      },
      {
        "r": "2CO.8.23",
        "v": 2
      },
      {
        "r": "3JN.1.8",
        "v": 2
      },
      {
        "r": "ACT.13.13",
        "v": 2
      },
      {
        "r": "PHP.2.25",
        "v": 2
      }
    ],
    "section": null
  },
  "PHM.1.25": {
    "text": "The grace of the Lord Jesus Christ be with your spirit.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2TI.4.22",
        "v": 7
      },
      {
        "r": "GAL.6.18",
        "v": 5
      },
      {
        "r": "ROM.16.20",
        "v": 5
      },
