    "section": null
  },
  "NAM.3.17": {
    "text": "Your guardsmen are like the swarming locust. Your marshals are like hordes of grasshoppers Settling in the stone walls on a cold day. The sun rises and they flee, And the place where they are is not known.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JER.51.27",
        "v": 3
