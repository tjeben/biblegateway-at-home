        "v": 6
      },
      {
        "r": "COL.4.15",
        "v": 4
      },
      {
        "r": "2TI.2.3-4",
        "v": 3
      },
      {
        "r": "1CO.16.19",
        "v": 3
      }
    ],
    "section": null
  },
