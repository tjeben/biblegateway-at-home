  "PHM.1.7": {
    "text": "For I have come to have much joy and comfort in your love, because the hearts of the saints have been refreshed through you, brother.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2CO.7.13",
        "v": 10
      },
      {
        "r": "1TH.3.9",
        "v": 6
      },
