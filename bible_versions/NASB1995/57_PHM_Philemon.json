      {
        "r": "1TH.2.19-20",
        "v": 2
      },
      {
        "r": "2CO.2.2",
        "v": 2
      },
      {
        "r": "1JN.3.17",
        "v": 2
      },
      {
        "r": "2CO.7.4-7",
        "v": 2
