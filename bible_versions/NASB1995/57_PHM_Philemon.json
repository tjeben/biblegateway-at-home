        "v": 3
      },
      {
        "r": "ACT.28.23",
        "v": 3
      },
      {
        "r": "PHP.1.19",
        "v": 3
      },
      {
        "r": "HEB.13.19",
        "v": 2
      },
      {
        "r": "PHP.1.25-26",
        "v": 2
      },
      {
        "r": "ROM.15.30-32",
