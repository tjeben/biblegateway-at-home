      {
        "r": "1TH.2.13",
        "v": 2
      }
    ],
    "section": null
  },
  "PHM.1.8": {
    "text": "Therefore, though I have enough confidence in Christ to order you to do what is proper,",
    "footnotes": [],
    "xrefs": [
      {
        "r": "1TH.2.6",
        "v": 8
      },
      {
        "r": "2CO.10.8",
        "v": 4
