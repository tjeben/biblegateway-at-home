        "v": 3
      },
      {
        "r": "LUK.15.20",
        "v": 3
      },
      {
        "r": "2SA.16.11",
        "v": 2
      },
      {
        "r": "DEU.13.6",
        "v": 2
      }
    ],
    "section": null
  },
