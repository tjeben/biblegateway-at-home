        "v": 2
      }
    ],
    "section": null
  },
  "JON.3.9": {
    "text": "Hvem vet? Gud kunne vende om og angre, ja, vende seg bort fra sin brennende vrede, så vi ikke skal gå fortapt.",
    "footnotes": [
      {
        "marker": "#",
        "text": "til grunne"
      }
    ],
    "xrefs": [
      {
        "r": "2SA.12.22",
