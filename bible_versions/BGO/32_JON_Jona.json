        "v": 2
      },
      {
        "r": "ISA.39.2",
        "v": 2
      },
      {
        "r": "AMO.6.13",
        "v": 1
      }
    ],
    "section": null
  },
  "JON.4.7": {
    "text": "Men da det grydde av morgen neste dag, utså Gud en orm, og den stakk Kikajonplanten så den visnet.",
    "footnotes": [],
    "xrefs": [
