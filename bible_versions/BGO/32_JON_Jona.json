  "JON.4.5": {
    "text": "Så gikk Jona ut av byen og satte seg øst for byen. Der lagde han en hytte og satte seg under den i skyggen, så han kunne se hva som ville skje med byen.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "1KI.19.9",
        "v": 3
      },
