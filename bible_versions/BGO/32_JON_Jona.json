  "JON.4.9": {
    "text": "Da sa Gud til Jona: «Er det rett at sinne blir opptent i deg på grunn av Kikajonplanten?» Han sa: «Ja, det er rett at sinne blir opptent i meg like til døden!»",
    "footnotes": [],
    "xrefs": [
      {
        "r": "GEN.4.5-14",
        "v": 2
      },
      {
        "r": "JOB.5.2",
