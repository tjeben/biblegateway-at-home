  "JON.1.13": {
    "text": "Mennene rodde hardt for å komme tilbake til land, men klarte det ikke, for sjøen gikk stadig høyere imot dem.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PRO.21.30",
        "v": 6
      },
      {
        "r": "JOB.34.29",
        "v": 3
      }
    ],
    "section": null
  },
  "JON.1.14": {
    "text": "Derfor ropte de til Herren og sa: «Å, Herre, vi ber Deg, la oss ikke gå til grunne for denne mannens liv, og la ikke uskyldig blod komme over oss. For Du, Herre, har gjort det som behaget Deg.»",
    "footnotes": [
      {
        "marker": "#",
        "text": "gå fortapt"
      },
      {
        "marker": "#",
        "text": "sjel"
      }
    ],
