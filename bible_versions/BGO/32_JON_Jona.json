        "v": 2
      },
      {
        "r": "ZEP.2.13-15",
        "v": 2
      },
      {
        "r": "JHN.5.14",
        "v": 2
      }
    ],
    "section": null
  },
  "JON.3.3": {
    "text": "Så sto Jona opp og gikk til Ninive etter Herrens Ord. Ninive var en stor by for Gud, tre dagsreiser i utstrekning.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PSA.80.10",
        "v": 1
      },
      {
        "r": "MAT.21.28-29",
        "v": 1
      },
      {
        "r": "GEN.22.3",
        "v": 1
      }
    ],
    "section": null
  },
  "JON.3.4": {
    "text": "Jona begynte å gå én dagsreise inn i byen. Så ropte han ut og sa: «Om 40 dager skal Ninive ødelegges.»",
    "footnotes": [],
    "xrefs": [
      {
        "r": "DEU.18.22",
        "v": 8
      },
      {
        "r": "JER.18.7-10",
        "v": 7
      },
      {
        "r": "2KI.20.1",
        "v": 3
      },
      {
        "r": "2KI.20.6",
        "v": 3
      },
      {
        "r": "JON.3.10",
        "v": 3
      }
    ],
    "section": null
  },
  "JON.3.5": {
    "text": "Da trodde folket i Ninive på Gud. De ropte ut en faste og kledde seg i sekkestrie, fra den største til den minste.",
