  "JON.4.1": {
    "text": "Men Jona syntes meget ondt om dette, og han ble rasende.",
    "footnotes": [
      {
        "marker": "#",
        "text": "at Gud angret"
      }
    ],
    "xrefs": [
      {
        "r": "JON.4.9",
        "v": 6
