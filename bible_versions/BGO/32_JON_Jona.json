    "section": null
  },
  "JON.3.7": {
    "text": "Han lot dette bli bekjentgjort i Ninive: Dette er kongens og hans stormenns befaling: Ikke noe menneske eller dyr, storfe eller småfe, må smake mat. La dem ikke ete mat eller drikke vann.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2CH.20.3",
        "v": 6
      },
      {
        "r": "JOL.2.15-16",
        "v": 5
      },
      {
        "r": "JON.3.5",
        "v": 5
      },
      {
        "r": "JOL.1.18",
        "v": 5
      },
      {
        "r": "EZR.8.21",
        "v": 4
      },
      {
        "r": "ROM.8.20-22",
        "v": 3
      }
    ],
    "section": null
  },
  "JON.3.8": {
    "text": "Både menneske og dyr skal dekkes med sekkestrie. De skal rope til Gud av all kraft. De skal vende om, hver og én fra sin onde ferd og fra volden som henger ved deres hender.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JON.1.6",
        "v": 4
