  "JON.2.11": {
    "text": "Så talte Herren til fisken, og den spydde Jona opp på tørt land.",
    "footnotes": [],
    "xrefs": [],
    "section": null
  },
  "JON.3.1": {
    "text": "Herrens Ord kom til Jona for andre gang, og det lød slik:",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JON.1.1",
        "v": 3
      }
    ],
    "section": "Jona forkynner i Ninive"
  },
  "JON.3.2": {
    "text": "«Stå opp, gå til Ninive, den store byen, og forkynn for den det budskapet Jeg sier deg.»",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JER.1.17",
        "v": 5
      },
      {
        "r": "EZK.2.7",
