      {
        "r": "ZEC.6.2",
        "v": 2
      },
      {
        "r": "ZEC.1.8",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.4": {
    "text": "Skjoldene til hans mektige er røde, stridsmennene er kledd i skarlagen. Vognene kommer med flammende fakler på hans forberedelses dag, og spydene svinges.",
    "footnotes": [
      {
        "marker": "#",
        "text": "bokst.: sypressene blir rystet; LXX og Syr.: hestene stormer omkring ; Vg.: Kuskene er sanseløse"
      }
    ],
    "xrefs": [
      {
        "r": "JER.4.13",
        "v": 4
      },
      {
        "r": "NAM.3.2-3",
        "v": 3
      },
      {
        "r": "EZK.26.10",
        "v": 3
      },
      {
        "r": "ISA.66.15",
        "v": 3
      },
      {
        "r": "ISA.37.24",
        "v": 2
      },
      {
        "r": "DAN.11.40",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.5": {
    "text": "Vognene raser fram i gatene, de kjører om hverandre på torgene. De ser ut som fakler, de farer av sted som lyn.",
    "footnotes": [
      {
        "marker": "#",
        "text": "eller: brede veier"
      }
    ],
    "xrefs": [
      {
        "r": "JER.46.12",
        "v": 5
      },
      {
        "r": "JER.51.27-28",
        "v": 2
      },
      {
        "r": "JER.50.29",
        "v": 2
      },
      {
        "r": "ISA.5.27",
        "v": 2
      },
      {
        "r": "NAM.3.3",
        "v": 2
      },
      {
        "r": "NAM.3.18",
        "v": 2
      },
      {
        "r": "ISA.21.5",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.6": {
    "text": "Han husker sine stormenn. De snubler der de går. De skynder seg til hennes mur, og skjoldtaket settes opp.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ISA.45.1-2",
        "v": 3
      },
      {
        "r": "2PE.3.10-11",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.7": {
    "text": "Elvenes porter er åpnet, og slottet ramler.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ISA.59.11",
        "v": 5
      },
      {
        "r": "ISA.38.14",
        "v": 5
      },
      {
        "r": "LUK.23.48",
        "v": 2
      },
      {
        "r": "ISA.32.12",
        "v": 2
      },
      {
        "r": "LUK.23.27",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.8": {
    "text": "Det er befalt: Ninive blir blottet, hun blir ført bort. Hennes tjenestepiker kurrer som duer, og de slår seg for sitt bryst.",
    "footnotes": [
      {
        "marker": "#",
        "text": "hebr.: huzzab"
      }
    ],
    "xrefs": [
      {
        "r": "REV.17.15",
        "v": 2
      },
      {
        "r": "REV.17.1",
        "v": 2
      },
      {
        "r": "JER.51.30",
        "v": 2
      },
      {
        "r": "GEN.10.11",
        "v": 2
      },
      {
        "r": "JER.50.16",
        "v": 2
      },
      {
        "r": "ISA.48.20",
        "v": 2
      },
      {
