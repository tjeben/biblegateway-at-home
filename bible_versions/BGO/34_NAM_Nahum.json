  "NAM.3.12": {
    "text": "Alle dine festningsverker er som fikentrær med den første frukten. Hvis de blir ristet, faller de i munnen på den som spiser.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "REV.6.13",
        "v": 4
      },
      {
        "r": "HAB.1.10",
        "v": 2
      },
      {
        "r": "ISA.28.4",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.3.13": {
    "text": "Sannelig, ditt folk midt iblant deg er som kvinner. Portene til ditt land står vidåpne for dine fiender. Ild fortærer dine bommer.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JER.51.30",
        "v": 6
      },
      {
        "r": "JER.50.37",
        "v": 5
      },
