      },
      {
        "r": "GEN.1.2",
        "v": 1
      }
    ],
    "section": null
  },
  "NAM.2.11": {
    "text": "Tom, folketom og øde! Hjertet mister motet, og knærne skjelver. Det er mye smerte i alle hofter, og alles ansikt blekner.",
    "footnotes": [
      {
        "marker": "#",
        "text": "Ninive"
      }
    ],
    "xrefs": [
      {
        "r": "ISA.5.29",
        "v": 5
