        "v": 2
      },
      {
        "r": "ISA.31.4",
        "v": 2
      },
      {
        "r": "JER.4.7",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.12": {
    "text": "Hvor er løvenes hule og stedet der de unge løvene eter? Hvor gikk løven, løvinnen og løveungen, uten at noen kunne skremme dem?",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JER.51.34",
        "v": 3
      },
      {
        "r": "ISA.10.6-14",
        "v": 2
      },
      {
        "r": "PSA.17.12",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.13": {
    "text": "Løven rev i filler, nok til sine unger, drepte for sin løvinne, fylte sitt hi med bytte og sine huler med det den hadde revet i filler.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JER.21.13",
        "v": 6
      },
      {
        "r": "PSA.46.9",
        "v": 6
      },
      {
        "r": "NAM.3.5",
        "v": 6
      },
      {
        "r": "2KI.19.23",
        "v": 5
      },
      {
        "r": "JOS.11.9",
        "v": 3
      },
      {
        "r": "2KI.19.9",
        "v": 3
      },
      {
        "r": "NAM.3.1",
        "v": 3
      },
      {
        "r": "EZK.5.8",
        "v": 3
      },
      {
        "r": "ISA.49.24-25",
        "v": 3
      },
