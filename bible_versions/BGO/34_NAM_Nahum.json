        "v": 0
      }
    ],
    "section": null
  },
  "NAM.2.2": {
    "text": "Han som vil spre utover, drar ut imot deg. Sett ut vakt i festningen! Hold utkikk langs veien! Styrk flankene! Sett ut hele styrken!",
    "footnotes": [
      {
        "marker": "#",
        "text": "Vg.: Han som ødelegger"
      },
      {
        "marker": "#",
        "text": "eller: hoftene"
      }
    ],
    "xrefs": [
      {
        "r": "PSA.80.12-13",
        "v": 5
      },
      {
        "r": "EZK.37.23",
        "v": 5
      },
      {
        "r": "ZEP.3.11",
        "v": 4
      },
      {
        "r": "ISA.60.15",
        "v": 3
