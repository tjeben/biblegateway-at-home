      {
        "r": "GEN.49.22-23",
        "v": 2
      }
    ],
    "section": "Ninives ødeleggelse"
  },
  "NAM.2.3": {
    "text": "For Herren gjenoppretter Jakobs stolthet slik som Israels stolthet, for de som legger øde, har plyndret dem og ødelagt deres vinranker.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "EZK.23.14-15",
        "v": 4
      },
      {
        "r": "ISA.63.1-3",
        "v": 3
      },
      {
        "r": "ZEC.11.2",
        "v": 2
      },
