        "r": "ISA.45.1-2",
        "v": 3
      },
      {
        "r": "PSA.107.16",
        "v": 2
      },
      {
        "r": "PSA.147.13",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.3.14": {
    "text": "Dra opp vann til du beleires. Forsterk dine festningsverker! Gå ut i leiren og trå mørtelen! Grip teglsteinsformen!",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2CH.32.3-4",
        "v": 4
