    ],
    "section": null
  },
  "NAM.3.8": {
    "text": "Er du bedre enn No-Amon, som lå ved Elven, som hadde vannene rundt seg, havet som festningsvoll, og havet som mur?",
    "footnotes": [
      {
        "marker": "#",
        "text": "dvs. gamle Teben; Tg. og Vg.: folkerike Alexandria"
      },
      {
        "marker": "#",
        "text": "bokst.: elvene, dvs. Nilen og de omkringliggende kanalene"
      }
    ],
    "xrefs": [
      {
