  },
  "NAM.2.1": {
    "text": "Se, på fjellene er føttene til ham som forkynner evangeliet, han som forkynner fred. Juda, hold dine høytider, oppfyll dine løfter. For den onde skal ikke mer trenge inn i deg, for han er fullstendig utryddet.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "JOL.3.9-11",
        "v": 9
      },
      {
        "r": "2CH.25.8",
        "v": 8
      },
      {
        "r": "JER.51.20-23",
        "v": 6
      },
      {
        "r": "JER.51.11-12",
        "v": 5
      },
      {
        "r": "JER.50.23",
        "v": 4
      },
      {
        "r": "JER.46.3-10",
        "v": 3
