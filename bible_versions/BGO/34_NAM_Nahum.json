        "v": 2
      },
      {
        "r": "NAM.3.17",
        "v": 2
      },
      {
        "r": "JER.46.5",
        "v": 2
      }
    ],
    "section": null
  },
  "NAM.2.9": {
    "text": "Selv om Ninive fra sine første dager var som en vanndam, flykter de nå bort. «Stans! Stans!» roper de. Men ingen snur seg tilbake.",
    "footnotes": [
      {
        "marker": "#",
        "text": "LXX: Ninive var en vanndam der vannet rant ut"
      }
    ],
    "xrefs": [
      {
        "r": "JER.51.56",
        "v": 2
      },
      {
        "r": "DAN.11.8",
        "v": 2
      },
      {
        "r": "2CH.36.10",
        "v": 2
      },
      {
        "r": "JER.25.34",
        "v": 2
      },
      {
        "r": "ISA.33.4",
        "v": 2
      },
      {
        "r": "NAM.2.12-13",
        "v": 2
      },
      {
        "r": "EZK.26.12",
        "v": 2
      },
      {
        "r": "ISA.33.1",
        "v": 1
      }
    ],
    "section": null
  },
  "NAM.2.10": {
    "text": "Ta bytte av sølv! Ta bytte av gull! Det er ingen ende på skattene og på rikdommen av alle slags kostbarheter.",
