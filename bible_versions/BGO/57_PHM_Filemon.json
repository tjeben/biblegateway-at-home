        "v": 4
      },
      {
        "r": "1TH.1.2",
        "v": 4
      },
      {
        "r": "2TI.1.3",
        "v": 2
      }
    ],
    "section": "Filemons kjærlighet og tro"
  },
  "PHM.1.5": {
    "text": "når jeg hører om den kjærlighet som du viser mot alle de hellige, og den tro du har til Herren Jesus.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "COL.1.4",
        "v": 10
      },
      {
        "r": "EPH.1.15",
        "v": 7
