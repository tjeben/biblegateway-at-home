      {
        "r": "LUK.15.24",
        "v": 3
      }
    ],
    "section": null
  },
  "PHM.1.12": {
    "text": "Jeg sender ham tilbake. Ta derfor imot ham, det vil si, mitt eget hjerte,",
    "footnotes": [
      {
        "marker": "#",
        "text": "UN: tilbake til deg personlig, det vil si, mitt eget hjerte ; se v. 7"
      }
    ],
    "xrefs": [
      {
        "r": "MAT.6.14-15",
        "v": 4
      },
      {
        "r": "MAT.18.21-35",
        "v": 3
      },
      {
        "r": "JER.31.20",
        "v": 3
      },
      {
        "r": "EPH.4.32",
        "v": 3
      },
      {
        "r": "MRK.11.25",
        "v": 3
      },
      {
        "r": "LUK.15.20",
        "v": 3
      },
      {
        "r": "2SA.16.11",
        "v": 2
      },
      {
        "r": "DEU.13.6",
        "v": 2
      }
    ],
    "section": null
  },
