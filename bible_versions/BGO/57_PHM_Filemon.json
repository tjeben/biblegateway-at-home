    "text": "så vil jeg likevel for kjærlighetens skyld heller oppmuntre deg, slik jeg er, Paulus, den aldrende, og nå også en Jesu Kristi fange.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "EPH.4.1",
        "v": 4
      },
      {
        "r": "ROM.12.1",
        "v": 4
      },
      {
        "r": "2CO.5.20",
        "v": 4
      },
      {
        "r": "EPH.3.1",
        "v": 3
      },
      {
        "r": "PHM.1.1-25",
        "v": 2
      },
      {
        "r": "1PE.2.11",
        "v": 1
