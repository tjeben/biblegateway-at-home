        "v": 1
      }
    ],
    "section": null
  },
  "PHM.1.10": {
    "text": "Jeg ber deg på vegne av min sønn Onesimos, som jeg er blitt åndelig far til mens jeg er i mine lenker.",
    "footnotes": [
      {
        "marker": "#",
        "text": "har hjulpet til nytt åndelig liv"
      }
    ],
    "xrefs": [
      {
        "r": "COL.4.9",
        "v": 9
      },
      {
        "r": "1CO.4.15",
        "v": 8
      },
      {
        "r": "GAL.4.19",
        "v": 7
      },
      {
        "r": "1TI.1.2",
        "v": 7
      },
      {
        "r": "TIT.1.4",
        "v": 6
      },
      {
        "r": "2SA.19.37-38",
        "v": 5
      },
      {
        "r": "2SA.18.5",
        "v": 4
      },
      {
        "r": "2SA.9.1-7",
        "v": 4
      },
      {
        "r": "MRK.9.17",
        "v": 3
      }
    ],
    "section": null
  },
