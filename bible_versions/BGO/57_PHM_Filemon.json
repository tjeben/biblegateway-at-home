    "text": "Min bønn er at den del du har i troen, må være virksom og øke din innsikt i alt det gode som er gitt dere i Kristus Jesus.",
    "footnotes": [
      {
        "marker": "#",
        "text": "UN og F-tekst: oss"
      }
    ],
    "xrefs": [
      {
        "r": "2PE.1.8",
        "v": 13
      },
      {
        "r": "PHP.1.9-11",
