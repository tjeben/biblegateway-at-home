      {
        "r": "1TH.2.13",
        "v": 2
      }
    ],
    "section": null
  },
  "PHM.1.8": {
    "text": "Derfor, selv om jeg kunne vært meget frimodig i Kristus og befalt deg å gjøre din plikt,",
    "footnotes": [],
    "xrefs": [
      {
        "r": "1TH.2.6",
        "v": 8
      },
      {
        "r": "2CO.10.8",
        "v": 4
      },
      {
        "r": "2CO.3.12",
        "v": 3
      },
