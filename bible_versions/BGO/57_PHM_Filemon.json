    "text": "Epafras, min medfange i Kristus Jesus, hilser deg.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "COL.1.7",
        "v": 5
      },
      {
        "r": "COL.4.12",
        "v": 4
      },
      {
        "r": "ROM.16.7",
        "v": 4
      },
      {
        "r": "COL.4.10",
        "v": 2
      }
    ],
    "section": "Farvel!"
  },
  "PHM.1.24": {
    "text": "Det samme gjør Markus, Aristarkos, Demas og Lukas, mine medarbeidere.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "COL.4.14",
        "v": 6
      },
      {
        "r": "2TI.4.10-11",
        "v": 6
      },
      {
        "r": "COL.4.10",
        "v": 6
