        "r": "EPH.5.4",
        "v": 2
      },
      {
        "r": "2CO.10.1-2",
        "v": 2
      },
      {
        "r": "1TH.2.2",
        "v": 2
      },
      {
        "r": "2CO.11.21",
        "v": 2
      }
    ],
