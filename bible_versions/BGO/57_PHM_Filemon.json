        "v": 3
      },
      {
        "r": "1CO.16.19",
        "v": 3
      }
    ],
    "section": null
  },
  "PHM.1.3": {
    "text": "Nåde være med dere og fred fra Gud, vår Far, og Herren Jesus Kristus!",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ROM.1.7",
        "v": 5
      },
      {
        "r": "EPH.1.2",
        "v": 4
      },
      {
        "r": "2CO.13.14",
        "v": 3
      }
    ],
    "section": null
  },
  "PHM.1.4": {
    "text": "Jeg takker min Gud og nevner deg alltid i mine bønner,",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ROM.1.8",
        "v": 7
      },
      {
        "r": "EPH.1.16",
        "v": 6
      },
