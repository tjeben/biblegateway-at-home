        "r": "1JN.5.1",
        "v": 1
      }
    ],
    "section": null
  },
  "PHM.1.17": {
    "text": "Hvis du da har samfunn med meg, så ta imot ham slik du ville ha tatt imot meg.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2CO.8.23",
        "v": 8
      },
      {
        "r": "MAT.10.40",
        "v": 6
      },
      {
        "r": "PHM.1.12",
        "v": 4
      },
      {
        "r": "MAT.18.5",
        "v": 3
      },
      {
        "r": "EPH.3.6",
        "v": 2
      },
      {
        "r": "JAS.2.5",
        "v": 2
      },
      {
        "r": "HEB.3.1",
        "v": 2
      },
      {
        "r": "MAT.12.48-50",
        "v": 2
      },
      {
        "r": "ACT.16.15",
        "v": 2
      },
      {
        "r": "MAT.25.40",
        "v": 2
      },
      {
        "r": "1TI.6.2",
        "v": 1
      },
      {
        "r": "HEB.3.14",
        "v": 1
      },
      {
        "r": "PHP.1.7",
        "v": 1
      },
      {
        "r": "1PE.5.1",
        "v": 1
      },
      {
        "r": "1JN.1.3",
        "v": 1
      },
      {
        "r": "PHM.1.10",
        "v": 1
      }
    ],
    "section": "Paulus stoler på Filemon"
  },
  "PHM.1.18": {
    "text": "Men hvis han har gjort noe galt mot deg eller skylder deg noe, så sett det på min regning.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ISA.53.4-7",
        "v": 7
      }
    ],
    "section": null
  },
  "PHM.1.19": {
    "text": "Jeg, Paulus, skriver med min egen hånd: Jeg skal betale tilbake – for ikke å nevne at du skylder meg til og med deg selv.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "GAL.6.11",
        "v": 4
      },
      {
        "r": "GAL.5.2",
        "v": 3
      },
      {
        "r": "1CO.16.21-22",
        "v": 3
      },
      {
        "r": "JAS.5.19-20",
        "v": 2
      },
      {
        "r": "1CO.4.15",
        "v": 2
      },
      {
        "r": "1CO.9.1-2",
        "v": 2
      },
      {
        "r": "2CO.3.2",
        "v": 1
      },
      {
        "r": "TIT.1.4",
        "v": 1
      },
      {
        "r": "1TI.1.2",
        "v": 1
      }
    ],
    "section": null
  },
