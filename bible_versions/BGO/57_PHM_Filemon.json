    "text": "til den kjære Appia og til vår kampfelle Arkippos og til menigheten i ditt hus:",
    "footnotes": [
      {
        "marker": "#",
        "text": "UN: til vår søster Appia"
      }
    ],
    "xrefs": [
      {
        "r": "PHP.2.25",
        "v": 7
