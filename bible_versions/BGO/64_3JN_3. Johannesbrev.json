  "3JN.1.13": {
    "text": "Jeg hadde mange ting å skrive, men jeg vil ikke skrive til deg med penn og blekk.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "2JN.1.12",
        "v": 6
      }
    ],
    "section": "Avskjedshilsen"
  },
  "3JN.1.14": {
    "text": "Men jeg håper å se deg om kort tid, og da skal vi tale muntlig sammen. Fred være med deg! Våre venner hilser deg. Hils vennene ved navn!",
    "footnotes": [],
