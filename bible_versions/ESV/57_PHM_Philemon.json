    "footnotes": [],
    "xrefs": [
      {
        "r": "2CO.7.13",
        "v": 10
      },
      {
        "r": "1TH.3.9",
        "v": 6
      },
      {
        "r": "2CO.7.4",
        "v": 6
      },
      {
        "r": "PHM.1.20",
        "v": 5
      },
