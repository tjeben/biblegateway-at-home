        "v": 7
      },
      {
        "r": "1TI.1.2",
        "v": 7
      },
      {
        "r": "TIT.1.4",
        "v": 6
      },
      {
        "r": "2SA.19.37-38",
        "v": 5
      },
      {
        "r": "2SA.18.5",
        "v": 4
