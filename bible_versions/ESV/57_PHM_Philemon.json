    "footnotes": [],
    "xrefs": [
      {
        "r": "ROM.1.8",
        "v": 7
      },
      {
        "r": "EPH.1.16",
        "v": 6
      },
      {
        "r": "COL.1.3",
        "v": 5
      },
      {
        "r": "PHP.1.3",
        "v": 5
