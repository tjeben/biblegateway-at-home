      {
        "r": "EPH.4.32",
        "v": 3
      },
      {
        "r": "MRK.11.25",
        "v": 3
      },
      {
        "r": "LUK.15.20",
        "v": 3
      },
      {
        "r": "2SA.16.11",
        "v": 2
      },
      {
        "r": "DEU.13.6",
        "v": 2
      }
    ],
    "section": null
  },
  "PHM.1.13": {
    "text": "I would have been glad to keep him with me, in order that he might serve me on your behalf during my imprisonment for the gospel,",
    "footnotes": [],
    "xrefs": [
      {
        "r": "PHP.1.7",
        "v": 4
      },
      {
        "r": "EPH.3.1",
        "v": 4
      },
      {
        "r": "1CO.16.17",
        "v": 3
      },
      {
        "r": "PHP.2.30",
        "v": 2
      },
      {
        "r": "EPH.4.1",
        "v": 2
      },
      {
        "r": "PHM.1.1",
        "v": 2
      }
    ],
    "section": null
  },
