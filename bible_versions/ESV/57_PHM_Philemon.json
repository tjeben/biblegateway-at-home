  "PHM.1.18": {
    "text": "If he has wronged you at all, or owes you anything, charge that to my account.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "ISA.53.4-7",
        "v": 7
      }
    ],
    "section": null
  },
  "PHM.1.19": {
    "text": "I, Paul, write this with my own hand: I will repay it—to say nothing of your owing me even your own self.",
    "footnotes": [],
    "xrefs": [
      {
        "r": "GAL.6.11",
        "v": 4
      },
      {
        "r": "GAL.5.2",
        "v": 3
      },
      {
        "r": "1CO.16.21-22",
        "v": 3
      },
      {
        "r": "JAS.5.19-20",
        "v": 2
      },
      {
        "r": "1CO.4.15",
        "v": 2
      },
      {
        "r": "1CO.9.1-2",
        "v": 2
      },
      {
        "r": "2CO.3.2",
        "v": 1
      },
      {
        "r": "TIT.1.4",
        "v": 1
      },
      {
        "r": "1TI.1.2",
        "v": 1
      }
    ],
    "section": null
  },
