        "v": 3
      },
      {
        "r": "1JN.3.23",
        "v": 2
      },
      {
        "r": "PHM.1.7",
        "v": 2
      },
      {
        "r": "GAL.5.6",
        "v": 2
      },
      {
        "r": "ROM.15.25-26",
