    "text": "For this perhaps is why he was parted from you for a while, that you might have him back forever,",
    "footnotes": [],
    "xrefs": [
      {
        "r": "GEN.50.20",
        "v": 7
      },
      {
        "r": "GEN.45.5-8",
        "v": 4
      },
      {
        "r": "ISA.20.6",
        "v": 2
      },
      {
        "r": "ACT.4.28",
        "v": 1
      }
    ],
    "section": null
  },
