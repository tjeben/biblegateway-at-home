        "r": "2CO.9.7",
        "v": 8
      },
      {
        "r": "1PE.5.2-3",
        "v": 3
      },
      {
        "r": "1CH.29.17",
        "v": 3
      },
      {
        "r": "PHM.1.8-9",
        "v": 2
      },
      {
        "r": "1CO.9.17",
        "v": 2
      },
      {
        "r": "2CO.8.12",
        "v": 2
      },
      {
        "r": "2CO.9.5",
        "v": 2
      },
      {
        "r": "2CO.1.24",
        "v": 1
      },
      {
        "r": "PSA.110.3",
        "v": 1
      }
    ],
    "section": null
  },
